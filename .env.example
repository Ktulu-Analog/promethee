# ─────────────────────────────────────────────────────────────────────────────
#  Prométhée AI Desktop — Configuration
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────
APP_TITLE=Prométhée
APP_USER=Pierre
APP_VERSION=2.2.3
SIDEBAR_MAX_CONVERSATIONS=15
HISTORY_DB=history.db


# ── Mode de fonctionnement ────────────────────────────────────────────────────
# LOCAL=ON  → Ollama (modèle local)
# LOCAL=OFF → Serveur OpenAI-compatible (Albert, défaut)
LOCAL='OFF'
OPENAI_API_BASE='https://albert.api.etalab.gouv.fr/v1'
OPENAI_API_KEY=******
OPENAI_MODEL='openai/gpt-oss-120b'
OLLAMA_BASE_URL='http://localhost:11434'
OLLAMA_MODEL='nemotron-3-nano:latest'


# ── Base vectorielle Qdrant ───────────────────────────────────────────────────
QDRANT_URL='http://localhost:6333'

# Identifiant utilisateur pour la collection Qdrant.
# Génère automatiquement une collection "promethee_<rag_user_id>".
# Si vide, le nom d'utilisateur système est utilisé.
RAG_USER_ID=pierre

# Surcharge manuelle du nom de collection (optionnel, déconseillé sur serveur partagé).
# QDRANT_COLLECTION=promethee_docs


# ── Embeddings ────────────────────────────────────────────────────────────────
# EMBEDDING_MODE : "api" (OpenAI-compatible) ou "local" (sentence-transformers)
EMBEDDING_MODE='api'
EMBEDDING_MODEL='BAAI/bge-m3'
EMBEDDING_API_BASE='https://albert.api.etalab.gouv.fr/v1'
EMBEDDING_DIMENSION='1024'


# ── RAG — Recherche documentaire ─────────────────────────────────────────────
RAG_TOP_K=25
RAG_MIN_SCORE=0.35
RAG_MAX_CHUNKS_PER_SOURCE=2
RAG_MAX_CHUNKS_TOTAL=20

# Recherche hybride Albert (dense BGE-M3 + sparse BM25)
# RAG_ALBERT_COLLECTION_IDS : IDs des collections Albert (vide = auto-découverte)
RAG_ALBERT_COLLECTION_IDS=
RAG_SEARCH_METHOD=hybrid
RAG_RERANK_ENABLED=ON
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3


# ── Mémoire long terme (LTM) ──────────────────────────────────────────────────
LTM_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506

LTM_ENABLED=ON
LTM_RECENT_K=2

# Résumés LLM : génère un résumé structuré par conversation au lieu de stocker
# les échanges bruts. Améliore la qualité des vecteurs. Nécessite LTM_ENABLED=ON.
# OFF = comportement historique (chunks bruts).
LTM_USE_SUMMARY=ON
LTM_SUMMARY_MAX_CHARS=1200

# Consolidation : tous les N cycles d'indexation, fusionne les anciens souvenirs
# en résumés thématiques pour limiter la croissance de la collection Qdrant.
# 0 = désactivé.
LTM_CONSOLIDATION_EVERY=5
LTM_CONSOLIDATION_MAX_CHUNKS=30


# ── Gestion du contexte ───────────────────────────────────────────────────────
# Fenêtre de contexte du modèle
CONTEXT_MODEL_MAX_TOKENS=128000

# Taille max de l'historique entrant (tokens réels). 0 = désactivé.
CONTEXT_HISTORY_MAX_TOKENS=90000

# Fallback en caractères si les tokens réels ne sont pas encore connus.
CONTEXT_HISTORY_MAX_CHARS=400000

# Taille max de la réponse générée (tokens)
MAX_CONTEXT_TOKENS=80000

# Taille max d'un résultat d'outil avant troncature symétrique (caractères)
TOOL_RESULT_MAX_CHARS=12000

# Nombre maximum d'itérations de la boucle agent
AGENT_MAX_ITERATIONS=12

# Compression des tool_results : après combien de tours agent. 0 = désactivé.
CONTEXT_AGENT_COMPRESS_AFTER=6
CONTEXT_TOOL_RESULT_SUMMARY_CHARS=8000

# Consolidation périodique de session : résumé LLM tous les N tours agent. 0 = désactivé.
CONTEXT_CONSOLIDATION_EVERY=8
CONTEXT_CONSOLIDATION_MAX_CHARS=6000
CONTEXT_PINNING_ENABLED=ON

# Consolidation adaptative : se déclenche quand prompt_tokens / CONTEXT_MODEL_MAX_TOKENS
# dépasse ce seuil. 0.0 = désactivé.
CONTEXT_CONSOLIDATION_PRESSURE_THRESHOLD=0.70

# ── HyDE — Hypothetical Document Embedding ───────────────────────────
RAG_HYDE_ENABLED=OFF               # ON = 1 appel LLM supplémentaire par requête RAG
RAG_HYDE_MAX_TOKENS=200            # Longueur du document hypothétique (150–300)

# ── Chunking contextuel (Anthropic Contextual Retrieval) ─────────────
RAG_CONTEXTUAL_CHUNKING=OFF        # ON = enrichit chaque chunk à l'ingestion (réingestion requise)
RAG_CONTEXTUAL_PREFIX_MAX_TOKENS=100   # Longueur du préfixe contextuel (80–150)
RAG_CONTEXTUAL_DOC_MAX_CHARS=10000     # Taille max du doc parent envoyé au LLM (8000–16000)

# ── Seuil de score adaptatif (mode Qdrant) ────────────────────────────
RAG_ADAPTIVE_THRESHOLD=ON          # ON = seuil dynamique | OFF = seuil fixe RAG_MIN_SCORE
RAG_ADAPTIVE_SIGMA=1.0             # 0.5 = permissif | 1.0 = équilibré | 1.5 = strict

RAG_INGESTION_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506

# ── Chiffrement de la base SQLite ─────────────────────────────────────────────
# DB_ENCRYPTION=ON  → conversations chiffrées sur disque (passphrase requise au démarrage)
# DB_ENCRYPTION=OFF → pas de chiffrement (défaut)
# ATTENTION : aucun mécanisme de récupération en cas d'oubli de passphrase.
DB_ENCRYPTION=OFF

# DB_ENCRYPTION_SEARCH=ON  → recherche FTS5 fonctionnelle (compromis sécurité)
# DB_ENCRYPTION_SEARCH=OFF → sécurité maximale, recherche désactivée
# Ignoré si DB_ENCRYPTION=OFF.
DB_ENCRYPTION_SEARCH=ON


# ── Grist ─────────────────────────────────────────────────────────────────────
GRIST_API_KEY=******
GRIST_BASE_URL=https://grist.numerique.gouv.fr


# ── APIs juridiques (PISTE) ───────────────────────────────────────────────────
# Inscriptions sur https://piste.gouv.fr

LEGIFRANCE_CLIENT_ID=******
LEGIFRANCE_CLIENT_SECRET=******
LEGIFRANCE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token
LEGIFRANCE_API_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app

JUDILIBRE_CLIENT_ID=******
JUDILIBRE_CLIENT_SECRET=******


# ── Messagerie IMAP (compte par défaut) ───────────────────────────────
IMAP_HOST=imap.******
IMAP_PORT=993
IMAP_USER=******
IMAP_PASSWORD=******
IMAP_SSL=ON
IMAP_DISPLAY_NAME=******
# IMAP_OAUTH2_TOKEN=  ← si OAuth2

SMTP_HOST=smtp.******
SMTP_PORT=465
SMTP_SSL=ON
# SMTP_USER et SMTP_PASSWORD héritent de IMAP si non définis

# ── Compte secondaire ──────────────────────────────────
# IMAP_PRO_HOST=...
# IMAP_PRO_USER=...
# IMAP_PRO_PASSWORD=...


# ── Recherche web ─────────────────────────────────────────────────────────────
# WEB_SEARCH_ENGINE : "ddg" (DuckDuckGo, défaut) ou "searxng" (auto-hébergé)
WEB_SEARCH_ENGINE=ddg
# WEB_SEARCH_SEARXNG_URL=http://localhost:8080
WEB_SEARCH_DEFAULT_LANG=fr-FR


# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_DEFAULT_LANG=fra+eng
OCR_MAX_PAGES=60


# ── Data Gouv ─────────────────────────────────────────────────────────────────
DATAGOUV_MCP_URL=https://mcp.data.gouv.fr/mcp
DATAGOUV_MCP_TIMEOUT=30
QDRANT_COLLECTION='promethee_pierre'
