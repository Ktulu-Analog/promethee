# =============================================================================
#  Prométhée AI — Variables d'environnement
#  Copier ce fichier en .env et renseigner les valeurs avant de démarrer.
# =============================================================================

# -----------------------------------------------------------------------------
#  Application
# -----------------------------------------------------------------------------

# Clé secrète de l'application (obligatoire)
# Générer avec : openssl rand -hex 32
PROMETHEE_SECRET_KEY=

# Port exposé par l'application sur l'hôte (défaut : 8000)
SERVER_PORT=8000

# Origines autorisées pour CORS (format JSON)
ALLOWED_ORIGINS=["http://localhost:8000"]

# Version affichée dans l'interface
APP_VERSION=3.0.1

# -----------------------------------------------------------------------------
#  LLM — Modèle de langage (obligatoire)
# -----------------------------------------------------------------------------

# URL du serveur LLM (Albert DiNum, OpenAI, serveur local...)
OPENAI_API_BASE=https://albert.api.etalab.gouv.fr/v1

# Clé API
OPENAI_API_KEY=

# Modèle à utiliser
OPENAI_MODEL=mistralai/Mistral-Small-3.1-24B-Instruct-2503

# -----------------------------------------------------------------------------
#  Qdrant — base vectorielle (RAG et mémoire long terme)
# -----------------------------------------------------------------------------

# URL du serveur Qdrant
QDRANT_URL=http://localhost:6333

# Clé d'API Qdrant (laisser vide pour désactiver l'authentification)
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
#  Garage — stockage objets compatible S3
# -----------------------------------------------------------------------------

# Clé RPC partagée entre les noeuds (obligatoire)
# Générer avec : openssl rand -hex 32
GARAGE_RPC_SECRET=

# Node ID du noeud Garage (obligatoire — voir Étape 2 du README)
# Récupérer avec :
#   docker compose up -d garage
#   docker exec promethee-garage /garage -c /etc/garage/garage.toml node id
# Copier la valeur hexadécimale avant le @ (ex: 56f7d01ee626b9672eb88de512607f13a79c53cb90b8f5d2195bd40cf6b147d6)
GARAGE_NODE_ID=

# Clé d'accès S3 (identifiant)
# Format obligatoire : GK + 24 caractères hex (ex: GKdf05b4d85d5dbb3f1cce490f6b1)
GARAGE_ACCESS_KEY=

# Clé d'accès S3 (secret)
# Format obligatoire : 64 caractères hex
# Générer avec : openssl rand -hex 32
GARAGE_SECRET_KEY=

# Nom du bucket S3
GARAGE_BUCKET=promethee-vfs

# -----------------------------------------------------------------------------
#  APIs juridiques — PISTE (optionnel)
# -----------------------------------------------------------------------------

# Identifiants PISTE pour Légifrance et Judilibre
LEGIFRANCE_CLIENT_ID=
LEGIFRANCE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
#  Messagerie IMAP/SMTP (optionnel)
# -----------------------------------------------------------------------------

IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

# -----------------------------------------------------------------------------
#  Grist — tableurs collaboratifs (optionnel)
# -----------------------------------------------------------------------------

GRIST_API_KEY=
GRIST_BASE_URL=https://docs.getgrist.com

# -----------------------------------------------------------------------------
#  Mémoire long terme — LTM (optionnel)
# -----------------------------------------------------------------------------

LTM_ENABLED=OFF
# Modèle dédié pour les résumés LTM (laisser vide = utilise OPENAI_MODEL)
LTM_MODEL=
LTM_USE_SUMMARY=OFF
LTM_RECENT_K=2

# -----------------------------------------------------------------------------
#  Options avancées
# -----------------------------------------------------------------------------

# Chiffrement de la base de données SQLite
DB_ENCRYPTION=OFF

# Boucle agent
AGENT_MAX_ITERATIONS=12
CONTEXT_CONSOLIDATION_EVERY=8
CONTEXT_CONSOLIDATION_PRESSURE_THRESHOLD=0.70
