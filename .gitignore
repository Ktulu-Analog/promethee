# ============================================================
#  Prométhée — .gitignore
# ============================================================

# ── Secrets & configuration locale ──────────────────────────
.env
*.env

# ── fonctions en test ──────────────────────────
qdrant_manager/

# ── Base de données ──────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Docker ───────────────────────────────────────────────────
# Les volumes Docker sont gérés par Docker, pas par Git
docker-compose.override.yml

# ── Assets JS téléchargés au build ───────────────────────────
# Générés par scripts/download_katex.py et download_mermaid.py
assets/katex/
assets/mermaid/

# ── Frontend — dépendances et build ──────────────────────────
frontend/node_modules/
frontend/dist/
node_modules/

# ── Scripts locaux ───────────────────────────────────────────
git_helper.py

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Distribution / packaging ─────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
*.whl

# ── Environnements virtuels ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Tests & couverture ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Fichiers temporaires ─────────────────────────────────────
*.tmp
*.bak
*.orig

# ── Outputs générés par Prométhée ────────────────────────────
exports/
output/
